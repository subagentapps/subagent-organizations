{
  "name": "@subagentapps/live-artifact",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "snapshot:projects": "bun run scripts/snapshot-projects.ts",
    "prebuild": "bun run scripts/snapshot-projects.ts",
    "build": "tsc -b && vite build",
