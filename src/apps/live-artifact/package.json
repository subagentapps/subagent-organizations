    "react-dom": "^19.0.0",
    "wouter": "^3.3.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^3.80.0"
  },
  "engines": {
    "node": ">=20"
  }
}
