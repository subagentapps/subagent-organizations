{
  "name": "@subagentapps/subagent-organizations",
  "version": "0.0.3",
  "description": "Typed manifest of zsh + Ghostty + Claude Code packages. TypeScript primitives with discriminated-union inheritance.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./primitives": "./dist/primitives/index.js",
    "./primitives/*": "./dist/primitives/*.js",
    "./directives": "./dist/directives/index.js",
    "./manifest": "./dist/manifest/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "render": "bun run scripts/render.ts",
    "verify": "bun run scripts/verify.ts",
    "parity-check": "bun run src/parity/check.ts",
    "kb:eval": "bun run tests/kb/contextual-retrieval.eval.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subagentapps/subagent-organizations.git"
  },
  "keywords": [
    "zsh",
    "ghostty",
    "claude-code",
    "manifest",
    "typescript"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
